# Gmail OAuth2 - Download credentials.json from Google Cloud Console
MY_EMAIL=your_gmail@gmail.com
MY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# LinkedIn (Playwright browser automation - no API key needed)
LINKEDIN_EMAIL=your_linkedin@email.com
LINKEDIN_PASSWORD=yourpassword

# Odoo ERP
ODOO_URL=https://your-odoo-instance.odoo.com
ODOO_DB=your_database_name
ODOO_USERNAME=your_odoo@email.com
ODOO_PASSWORD=your_odoo_password

# Facebook (Playwright browser automation)
FACEBOOK_EMAIL=your_facebook@email.com
FACEBOOK_PASSWORD=your_facebook_password

# Instagram (Playwright browser automation)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Twitter / X (Playwright browser automation)
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
